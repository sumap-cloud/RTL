import pytest
from unittest.mock import MagicMock, call
import pos_main  # Import the script we want to test

def test_main_flow_success(mocker):
    """
    Tests the main function for a successful transaction flow.
    It mocks the POSFlowManager to simulate successful operations.
    """
    # 1. Create a mock for the POSFlowManager class
    mock_pos_flow_instance = MagicMock()
    
    # 2. Configure the mock methods to return True, simulating success
    mock_pos_flow_instance.ensure_pos_ready.return_value = True
    mock_pos_flow_instance.add_articles.return_value = True
    mock_pos_flow_instance.handle_loyalty.return_value = True
    mock_pos_flow_instance.handle_additional_popups.return_value = True
    mock_pos_flow_instance.complete_transaction.return_value = True
    
    # 3. Use mocker to replace the real POSFlowManager with our mock
    #    When pos_main.POSFlowManager() is called, it will return our mock_pos_flow_instance
    mocker.patch('pos_main.POSFlowManager', return_value=mock_pos_flow_instance)
    
    # 4. Run the main function
    result = pos_main.main()
    
    # 5. Assert that the flow completed successfully
    assert result is True, "The main function should return True on success"
    
    # 6. Assert that all methods were called in the correct order
    expected_calls = [
        call.ensure_pos_ready(),
        call.add_articles([
            "9300675084147",
            "9300675084147",
            "9300675084147"
        ]),
        call.handle_loyalty(),
        call.handle_additional_popups(),
        call.complete_transaction(payment_method="eft"),
        call.reset_focus()
    ]
    mock_pos_flow_instance.assert_has_calls(expected_calls, any_order=False)


def test_main_flow_fails_on_pos_not_ready(mocker):
    """
    Tests that the main function returns False if the POS is not ready.
    """
    # 1. Create a mock instance
    mock_pos_flow_instance = MagicMock()
    
    # 2. Configure the mock to simulate failure at the first step
    mock_pos_flow_instance.ensure_pos_ready.return_value = False
    
    # 3. Patch the class
    mocker.patch('pos_main.POSFlowManager', return_value=mock_pos_flow_instance)
    
    # 4. Run the main function
    result = pos_main.main()
    
    # 5. Assert that the flow failed as expected
    assert result is False, "The main function should return False when POS is not ready"
    
    # 6. Verify that the flow stopped after the first call
    mock_pos_flow_instance.ensure_pos_ready.assert_called_once()
    mock_pos_flow_instance.add_articles.assert_not_called()
    mock_pos_flow_instance.complete_transaction.assert_not_called()

def test_main_flow_fails_on_add_articles(mocker):
    """
    Tests that the main function returns False if adding articles fails.
    """
    # 1. Create a mock instance
    mock_pos_flow_instance = MagicMock()
    
    # 2. Configure the mock to simulate success on the first step and failure on the second
    mock_pos_flow_instance.ensure_pos_ready.return_value = True
    mock_pos_flow_instance.add_articles.return_value = False
    
    # 3. Patch the class
    mocker.patch('pos_main.POSFlowManager', return_value=mock_pos_flow_instance)
    
    # 4. Run the main function
    result = pos_main.main()
    
    # 5. Assert that the flow failed
    assert result is False, "The main function should return False when adding articles fails"
    
    # 6. Verify that the flow stopped after the second call
    mock_pos_flow_instance.ensure_pos_ready.assert_called_once()
    mock_pos_flow_instance.add_articles.assert_called_once()
    mock_pos_flow_instance.complete_transaction.assert_not_called()
